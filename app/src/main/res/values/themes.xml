<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ContasDomesticas" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
    </style>

    <!--
      Tema de splash (androidx.core:core-splashscreen).
      Scaffolding pronto — para ATIVAR: usar como tema de launch no Manifest e chamar
      installSplashScreen() no onCreate (rodada de codigo).
    -->
    <style name="Theme.ContasDomesticas.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/purple_700</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.ContasDomesticas</item>
    </style>
</resources>
